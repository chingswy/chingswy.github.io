---
import Base from "../layouts/Base.astro";
import Viewer3D from "../components/Viewer3D.astro";
import bioSource from "../data/bio.md?raw";
import papersSource from "../data/papers.bib?raw";
import { parseBib } from "../utils/parseBib";

const escapeHtml = (s: string) =>
  s.replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");

const renderInline = (text: string) => {
  let out = escapeHtml(text);
  out = out.replace(
    /\[([^\]]+)\]\(([^)\s]+)\)/g,
    (_m, label, href) => `<a href="${href}">${label}</a>`,
  );
  out = out.replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");
  out = out.replace(/(^|[^*])\*([^*\n]+)\*/g, "$1<em>$2</em>");
  return out;
};

const bioParagraphs = bioSource
  .split(/\n{2,}/)
  .map((p) => p.trim())
  .filter(Boolean)
  .map(renderInline);

const experience = [
  {
    range: "2024 —",
    role: "Senior Researcher",
    org: "Tencent Hunyuan",
    place: "Shenzhen, China",
    detail:
      "Main driver of 3D human motion generation from multimodal control inputs, taking the technology from research prototype to production. Along the way, built out a full pipeline spanning data curation, model training, evaluation, and deployment. Also open-sourced part of this work as HY-Motion, which reached the Hugging Face weekly trending list.",
  },
  {
    range: "2019 — 2024",
    role: "Ph.D. in Computer Science",
    org: "Zhejiang University · State Key Lab of CAD & CG",
    place: "Hangzhou, China",
    detail:
      "Advised by Prof. Xiaowei Zhou. Focused on markerless motion capture and neural scene representations. Designed and maintained EasyMocap, a widely used open-source toolkit and currently the most starred motion capture system on GitHub. Published at CVPR, ICCV, ECCV, and SIGGRAPH — building a solid foundation in computer vision and computer graphics.",
  },
  {
    range: "2015 — 2019",
    role: "B.Eng. in Mechanical Engineering",
    org: "Zhejiang University · Chu Kochen Honors College",
    place: "Hangzhou, China",
    detail:
      "Coursework centered on modern control theory and the theory of wheeled and legged robots. The engineering mindset — sensing, actuation, and feedback — later shaped how I approach vision and 3D.",
  },
];

const projects = [
  {
    title: "EasyMocap",
    subtitle: "Open-source infrastructure for capturing human data.",
    story:
      "Understanding people starts with data. EasyMocap turns a handful of ordinary cameras into a full pipeline for markerless motion capture — calibration, keypoint estimation, and SMPL fitting — bringing 3D human data within reach of anyone with a few cameras.",
    href: "https://github.com/zju3dv/EasyMocap",
    repo: "zju3dv/EasyMocap",
    video: "/videos/easymocap.mp4",
  },
  {
    title: "LoG",
    subtitle: "Real-time interactive photorealistic 3D scenes.",
    story:
      "Behavior only makes sense inside a world. LoG (Level-of-Gaussians) proposes an adaptive hierarchical Gaussian representation whose level of detail follows the viewpoint, delivering real-time interaction across scales — from a single object to an entire city.",
    href: "https://github.com/zju3dv/LoG",
    repo: "zju3dv/LoG",
    video: "/videos/log.mp4",
  },
  {
    title: "HY-Motion 1.0",
    subtitle: "Understanding and generating human motion.",
    story:
      "The last step is turning human intent into motion. We curated a large-scale human motion dataset and trained an MMDiT generative model on it, producing 3D human motion from language, audio, and control signals — with strong instruction understanding and fine-grained controllability.",
    href: "https://github.com/Tencent-Hunyuan/HY-Motion-1.0",
    repo: "Tencent-Hunyuan/HY-Motion-1.0",
    video: "/videos/hy-motion.mp4",
  },
];

const papers = parseBib(papersSource);

// Fetch GitHub star counts at build time so the browser never hits the API.
// Uses GITHUB_TOKEN in CI (5000/hr). Locally, unauthenticated (60/hr) or missing
// network gracefully falls back to null (renders as "—").
const projectRepos = ["zju3dv/EasyMocap", "zju3dv/LoG", "Tencent-Hunyuan/HY-Motion-1.0"];
const starHeaders: Record<string, string> = {
  Accept: "application/vnd.github+json",
  "X-GitHub-Api-Version": "2022-11-28",
};
if (process.env.GITHUB_TOKEN) {
  starHeaders.Authorization = `Bearer ${process.env.GITHUB_TOKEN}`;
}
const starCounts: Record<string, number | null> = {};
await Promise.all(
  projectRepos.map(async (repo) => {
    try {
      const res = await fetch(`https://api.github.com/repos/${repo}`, {
        headers: starHeaders,
      });
      if (!res.ok) throw new Error(`${res.status}`);
      const data = (await res.json()) as { stargazers_count?: number };
      starCounts[repo] = typeof data.stargazers_count === "number" ? data.stargazers_count : null;
    } catch (err) {
      console.warn(`[stars] failed for ${repo}:`, (err as Error).message);
      starCounts[repo] = null;
    }
  }),
);

const formatStars = (n: number): string => {
  if (n >= 10000) return `${(n / 1000).toFixed(1).replace(/\.0$/, "")}k`;
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`;
  return String(n);
};

const byYear = papers.reduce<Record<number, typeof papers>>((acc, p) => {
  (acc[p.year] ??= []).push(p);
  return acc;
}, {});
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);

const isVideo = (src?: string) => !!src && /\.(mp4|webm|mov)$/i.test(src);
const renderAuthors = (authors: string[]) =>
  authors
    .map((a) => {
      const starred = a.endsWith("*");
      const name = starred ? a.slice(0, -1) : a;
      const highlight = name === "Qing Shuai";
      const rendered = highlight ? `<strong>${name}</strong>` : name;
      return starred ? `${rendered}<sup>*</sup>` : rendered;
    })
    .join(", ");
---

<Base>
  {/* ============ HERO ============ */}
  <section id="home" class="page hero" data-title="Home">
    <div class="page-inner hero-inner">
      <div class="hero-portrait">
        <Viewer3D size={260} hint="Drag to view" />
        <p class="hero-portrait-caption">
          Captured in 2021 with our <em>MonoStage</em> algorithm.
        </p>
      </div>

      <div class="hero-copy">
        <h1 class="hero-name">
          Qing Shuai <span class="hero-name-cn">帅青</span>
        </h1>
        <div class="hero-bio-block">
          {bioParagraphs.map((html) => (
            <p class="hero-bio" set:html={html} />
          ))}
        </div>
        <div class="hero-links">
          <a href="mailto:s_q@zju.edu.cn">Email</a>
          <a href="https://github.com/chingswy">GitHub</a>
          <a href="https://scholar.google.com/citations?user=51lY6vIAAAAJ">
            Google Scholar
          </a>
          <a href="https://www.zhihu.com/people/shuaiqing-32">Zhihu</a>
        </div>
      </div>
    </div>

    <a href="#experience" class="scroll-hint" aria-label="Scroll down">
      <span class="scroll-hint-arrow">↓</span>
    </a>
  </section>

  {/* ============ EXPERIENCE ============ */}
  <section id="experience" class="page" data-title="Experience">
    <div class="page-inner">
      <header class="section-head">
        <h2>Experience</h2>
      </header>
      <ol class="timeline">
        {
          experience.map((e) => (
            <li class="tl-item">
              <div class="tl-range"><span>{e.range}</span></div>
              <div class="tl-body">
                <h3 class="tl-role">{e.role}</h3>
                <p class="tl-org">
                  <span>{e.org}</span>
                  <span class="tl-sep">·</span>
                  <span class="tl-place">{e.place}</span>
                </p>
                <p class="tl-detail">{e.detail}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  {/* ============ FEATURED PROJECTS ============ */}
  <section id="projects" class="page" data-title="Projects">
    <div class="page-inner">
      <header class="section-head">
        <h2>Featured projects</h2>
        <p class="lede proj-lede">
          A thread runs through my work: how do we turn the physical world and
          human behavior into something a computer can perceive, model, and act
          within? The three projects below attack three sides of that question
          — <em>perceiving</em> people, <em>modeling</em> the world they inhabit,
          and <em>acting</em> inside it. The long-term goal is an AI that
          understands and moves through the real world the way we do.
        </p>
      </header>
      <ul class="proj-list">
        {
          projects.map((p) => {
            const [username, reponame] = p.repo.split("/");
            const starId = `stars-${username}-${reponame}`;
            return (
            <li class="proj-item">
              <h3 class="proj-title">
                <a href={p.href}>{p.title}</a>
              </h3>
              <p class="proj-subtitle">{p.subtitle}</p>
              <button
                type="button"
                class="proj-video"
                data-video={p.video}
                data-title={p.title}
                aria-label={`Play ${p.title} preview`}
              >
                <video
                  data-src={p.video}
                  muted
                  loop
                  playsinline
                  preload="none"
                  aria-hidden="true"
                />
                <span class="media-loader" aria-hidden="true">
                  <span class="media-loader-track"><span class="media-loader-fill"></span></span>
                  <span class="media-loader-label">Loading</span>
                </span>
                <span class="proj-video-cta" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
                    <path fill="currentColor" d="M8 5v14l11-7z"/>
                  </svg>
                  <span>Click to view</span>
                </span>
              </button>
              <p class="proj-story">{p.story}</p>
              <div class="proj-meta-row">
                <a class="proj-link proj-repo-link" href={p.href}>
                  <svg class="proj-icon" viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
                    <path fill="currentColor" fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/>
                  </svg>
                  <span>{p.repo}</span>
                </a>
                {p.demoHref && (
                  <a class="proj-link" href={p.demoHref}>{p.demoLabel}</a>
                )}
              </div>
              <a class="proj-star-row" href={p.href} aria-label={`${p.title} on GitHub`}>
                <svg class="proj-star-icon" viewBox="0 0 16 16" width="18" height="18" aria-hidden="true">
                  <path fill="currentColor" d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.72 4.192a.75.75 0 01-1.088.791L8 12.347l-3.767 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/>
                </svg>
                <span id={starId} class="proj-star-count">
                  {starCounts[p.repo] != null ? formatStars(starCounts[p.repo] as number) : "—"}
                </span>
                <span class="proj-star-label">stars</span>
              </a>
            </li>
            );
          })
        }
      </ul>
    </div>
  </section>

  {/* ============ PUBLICATIONS ============ */}
  <section id="publications" class="page scrollable" data-title="Publications">
    <div class="page-inner">
      <header class="section-head">
        <h2>Publications</h2>
        <p class="lede">
          Selected papers, most recent first. See{" "}
          <a href="https://scholar.google.com/citations?user=51lY6vIAAAAJ">
            Google Scholar
          </a>{" "}
          for the complete list.
        </p>
      </header>

      {
        years.map((year) => (
          <div class="year-block">
            <div class="year-head">
              <span class="year-label">{year}</span>
            </div>
            <ul class="paper-list">
              {byYear[year].map((p) => (
                <li class="paper-item">
                  {p.preview ? (
                    <button
                      type="button"
                      class="paper-preview paper-preview-btn"
                      data-media={p.preview}
                      data-media-type={isVideo(p.preview) ? "video" : "image"}
                      data-title={p.title}
                      aria-label={`Open ${p.title} preview`}
                    >
                      {isVideo(p.preview) ? (
                        <video
                          data-src={p.preview}
                          muted
                          loop
                          playsinline
                          preload="none"
                          aria-hidden="true"
                        />
                      ) : (
                        <img
                          data-src={p.preview}
                          alt=""
                          decoding="async"
                        />
                      )}
                      <span class="media-loader" aria-hidden="true">
                        <span class="media-loader-track"><span class="media-loader-fill"></span></span>
                        <span class="media-loader-label">Loading</span>
                      </span>
                      <span class="paper-preview-cta" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true">
                          <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M15 3h6v6M14 10l7-7M9 21H3v-6M10 14l-7 7"/>
                        </svg>
                      </span>
                    </button>
                  ) : (
                    <div class="paper-preview">
                      <div class="paper-preview-empty" aria-hidden="true" />
                    </div>
                  )}
                  <div class="paper-text">
                    <h3 class="paper-title">{p.title}</h3>
                    <p class="paper-authors" set:html={renderAuthors(p.authors)} />
                    <div class="paper-meta-row">
                      {p.venueHref ? (
                        <a href={p.venueHref} class="meta paper-venue paper-venue-link">{p.venue}</a>
                      ) : (
                        <span class="meta paper-venue">{p.venue}</span>
                      )}
                      {p.links.map((l) => (
                        <a href={l.href} class="paper-link">{l.label}</a>
                      ))}
                      <button
                        type="button"
                        class="paper-link paper-bibtex"
                        data-bibtex={p.bibtex}
                      >
                        BibTeX
                      </button>
                    </div>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  {/* ============ VIDEO MODAL ============ */}
  <div id="video-modal" class="video-modal" role="dialog" aria-modal="true" aria-hidden="true">
    <button type="button" class="video-modal-backdrop" aria-label="Close"></button>
    <div class="video-modal-panel" role="document">
      <button type="button" class="video-modal-close" aria-label="Close">
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" d="M6 6l12 12M18 6L6 18"/>
        </svg>
      </button>
      <div class="video-modal-title" id="video-modal-title"></div>
      <video
        class="video-modal-video"
        controls
        controlsList="nodownload"
        playsinline
        preload="metadata"
      ></video>
      <img class="video-modal-image" alt="" />
    </div>
  </div>
</Base>

<style>
  /* ================ HERO ================ */
  .hero-inner {
    display: grid;
    grid-template-columns: minmax(200px, 300px) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }
  .hero-portrait { display: flex; flex-direction: column; align-items: center; gap: 2.75rem; }
  .hero-portrait-caption {
    color: var(--fg-mute);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.01em;
    text-align: center;
    max-width: 220px;
    margin: 0;
  }
  .hero-portrait-caption em { font-style: italic; color: var(--fg-soft); }
  .hero-name {
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 1.75rem;
  }
  .hero-name-cn {
    color: var(--fg-mute);
    font-size: 0.55em;
    margin-left: 0.4em;
    letter-spacing: 0;
    font-weight: 300;
  }
  .hero-bio-block {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .hero-bio {
    color: var(--fg-soft);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 44rem;
  }
  .hero-bio em { color: var(--fg); font-style: italic; }
  .hero-bio strong { font-weight: 500; color: var(--fg); }
  .hero-links {
    display: flex;
    gap: 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
  }
  .hero-links a { border-bottom-color: var(--rule); }
  .hero-links a:hover { border-color: var(--accent); }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    text-decoration: none !important;
    color: var(--fg-mute);
    font-size: 18px;
    animation: bob 2.2s ease-in-out infinite;
  }
  .scroll-hint:hover { color: var(--accent); }
  @keyframes bob {
    0%, 100% { transform: translate(-50%, 0); }
    50%      { transform: translate(-50%, 8px); }
  }

  @media (max-width: 780px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-bio { margin-inline: auto; }
    .hero-links { justify-content: center; flex-wrap: wrap; }
  }

  /* ================ EXPERIENCE / TIMELINE ================ */
  .timeline {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  .tl-item {
    display: grid;
    grid-template-columns: minmax(120px, 160px) 1fr;
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: baseline;
  }
  .tl-range {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--fg-mute);
    padding-top: 0.35rem;
  }
  .tl-role { font-size: 1.35rem; font-weight: 500; margin-bottom: 0.25rem; }
  .tl-org {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--fg-soft);
    margin-bottom: 0.75rem;
  }
  .tl-org .tl-sep { margin: 0 0.5rem; color: var(--fg-mute); }
  .tl-place { color: var(--fg-mute); }
  .tl-detail { color: var(--fg-soft); line-height: 1.7; max-width: 50rem; }

  @media (max-width: 640px) {
    .tl-item { grid-template-columns: 1fr; gap: 0.5rem; }
    .tl-range { padding-top: 0; }
  }

  /* ================ PROJECTS ================ */
  .proj-lede { max-width: none; }
  .proj-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  .proj-item {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .proj-video {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: color-mix(in oklab, var(--fg-mute) 8%, transparent);
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 3px;
    margin-bottom: 1.1rem;
    position: relative;
    cursor: pointer;
    color: inherit;
    font: inherit;
    transition: box-shadow 300ms ease, transform 300ms ease;
  }
  .proj-video:hover {
    box-shadow: 0 12px 30px -12px rgba(0, 0, 0, 0.25);
  }
  .proj-video:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .proj-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .proj-video-cta {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    background: rgba(0, 0, 0, 0.32);
    opacity: 0;
    transition: opacity 220ms ease, background 220ms ease;
    pointer-events: none;
  }
  .proj-video-cta > svg,
  .proj-video-cta > span {
    box-sizing: border-box;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.94);
    color: #0f1115;
    transition: background 220ms ease;
  }
  .proj-video-cta > svg {
    width: 34px;
    padding: 0 0 0 4px;
    border-radius: 999px 0 0 999px;
    box-shadow: -6px 0 22px rgba(0, 0, 0, 0.35);
  }
  .proj-video-cta > span {
    padding: 0 0.95rem 0 0.55rem;
    border-radius: 0 999px 999px 0;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    line-height: 1;
    box-shadow: 6px 0 22px rgba(0, 0, 0, 0.35);
  }
  .proj-video.is-ready .proj-video-cta { opacity: 1; }
  .proj-video.is-ready:hover .proj-video-cta {
    background: rgba(0, 0, 0, 0.48);
  }
  .proj-video.is-ready:hover .proj-video-cta > svg,
  .proj-video.is-ready:hover .proj-video-cta > span {
    background: #fff;
  }
  .proj-title { font-size: 1.25rem; margin-bottom: 0.35rem; font-weight: 500; }
  .proj-title a { border-bottom: none; }
  .proj-title a:hover { color: var(--accent); }
  .proj-subtitle {
    color: var(--fg-mute);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    line-height: 1.4;
    margin-bottom: 1rem;
  }
  .proj-story { color: var(--fg-soft); line-height: 1.65; font-size: 0.95rem; margin-bottom: 1rem; }
  .proj-meta-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-top: auto;
  }
  .proj-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--fg-mute);
    border-bottom: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1;
  }
  .proj-link:hover { color: var(--accent); }
  .proj-icon { flex: none; }
  .proj-star-row {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-top: 0.85rem;
    color: var(--fg);
    border-bottom: none;
    font-family: var(--font-sans);
    line-height: 1;
    align-self: flex-start;
  }
  .proj-star-row:hover { color: var(--accent); }
  .proj-star-icon {
    color: var(--accent);
    transform: translateY(3px);
  }
  .proj-star-count {
    font-size: 1.6rem;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.01em;
  }
  .proj-star-label {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-mute);
  }
  .lede em { color: var(--fg); font-style: italic; }

  @media (max-width: 900px) {
    .proj-list { grid-template-columns: 1fr; }
  }

  /* ================ PUBLICATIONS ================ */
  .pubs-lede { color: var(--fg-soft); margin-bottom: 3rem; max-width: 44rem; }
  .year-block { margin-bottom: 3rem; }
  .year-block:last-child { margin-bottom: 0; }
  .year-head {
    border-bottom: 1px solid var(--rule);
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .year-label {
    font-family: var(--font-sans);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-mute);
    font-feature-settings: "ss01", "cv11";
  }
  .paper-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }
  .paper-item {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  .paper-preview {
    width: 160px;
    aspect-ratio: 4 / 3;
    background: color-mix(in oklab, var(--fg-mute) 8%, transparent);
    overflow: hidden;
    border-radius: 2px;
    display: flex;
    position: relative;
  }
  .paper-preview-btn {
    padding: 0;
    border: none;
    color: inherit;
    font: inherit;
    cursor: pointer;
    transition: box-shadow 200ms ease;
  }
  .paper-preview-btn:hover {
    box-shadow: 0 8px 22px -10px rgba(0, 0, 0, 0.35);
  }
  .paper-preview-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .paper-preview-cta {
    position: absolute;
    top: 6px;
    right: 6px;
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    opacity: 0;
    transition: opacity 200ms ease, background 200ms ease;
    pointer-events: none;
  }
  .paper-preview-btn.is-ready .paper-preview-cta { opacity: 1; }
  .paper-preview-btn.is-ready:hover .paper-preview-cta { background: rgba(0, 0, 0, 0.75); }
  .paper-preview img,
  .paper-preview video {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .paper-preview-empty {
    width: 100%;
    aspect-ratio: 4 / 3;
  }
  .paper-text { min-width: 0; }
  .paper-title { font-size: 1.05rem; line-height: 1.45; margin-bottom: 0.25rem; font-weight: 500; }
  .paper-authors {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--fg-soft);
    margin-bottom: 0.5rem;
  }
  .paper-authors :global(strong) { color: var(--fg); font-weight: 600; }
  .paper-authors :global(sup) { font-size: 0.7em; color: var(--fg-mute); }
  .paper-meta-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .paper-venue { color: var(--accent); }
  .paper-venue-link { border-bottom: none; }
  .paper-venue-link:hover { opacity: 0.75; }
  .paper-link {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--fg-mute);
    border-bottom: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    line-height: 1;
  }
  .paper-link:hover { color: var(--accent); }
  .paper-bibtex {
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
  }
  .paper-bibtex.copied { color: var(--accent); }

  @media (max-width: 640px) {
    .paper-item { grid-template-columns: 110px 1fr; gap: 1rem; }
    .paper-preview { width: 110px; }
  }

  /* ================ MEDIA LOADER ================ */
  .media-loader {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    background: color-mix(in oklab, var(--bg) 92%, var(--fg-mute) 8%);
    opacity: 1;
    transition: opacity 300ms ease;
    pointer-events: none;
    z-index: 3;
  }
  .media-loader.is-hidden { opacity: 0; }
  .media-loader-track {
    position: relative;
    width: min(60%, 140px);
    height: 3px;
    border-radius: 2px;
    background: color-mix(in oklab, var(--fg-mute) 22%, transparent);
    overflow: hidden;
  }
  .media-loader-fill {
    position: absolute;
    inset: 0;
    right: auto;
    width: 0%;
    background: var(--accent);
    transition: width 220ms ease-out;
  }
  .media-loader-label {
    font-family: var(--font-sans);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-mute);
  }
  .paper-preview { position: relative; }
  .paper-preview .media-loader-track { width: min(70%, 110px); }
  .paper-preview .media-loader-label { font-size: 9.5px; }

  /* ================ VIDEO MODAL ================ */
  .video-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: none;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 4vw, 3rem);
  }
  .video-modal.is-open {
    display: flex;
    animation: modal-fade 220ms ease-out;
  }
  @keyframes modal-fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  .video-modal-backdrop {
    position: absolute;
    inset: 0;
    border: none;
    padding: 0;
    margin: 0;
    background: rgba(0, 0, 0, 0.72);
    backdrop-filter: blur(6px);
    cursor: pointer;
  }
  .video-modal-panel {
    position: relative;
    width: min(1200px, 92vw);
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    z-index: 1;
  }
  .video-modal-title {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.85);
    padding-right: 3rem;
  }
  .video-modal-close {
    position: absolute;
    top: -0.25rem;
    right: -0.25rem;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 200ms ease;
  }
  .video-modal-close:hover { background: rgba(255, 255, 255, 0.24); }
  .video-modal-video,
  .video-modal-image {
    width: 100%;
    max-height: 82vh;
    background: #000;
    border-radius: 4px;
    display: block;
    object-fit: contain;
  }
  .video-modal-image { display: none; background: transparent; }
  .video-modal[data-kind="image"] .video-modal-video { display: none; }
  .video-modal[data-kind="image"] .video-modal-image { display: block; }
</style>

<script>
  // ---------- Simulated progress bar ----------
  // The browser doesn't reliably expose "how much of this video/image has
  // downloaded" until after headers arrive, so we ease a fake bar to ~92%,
  // then finish it when the media reports ready.
  function driveLoader(container: HTMLElement, mediaReady: Promise<void>) {
    const loader = container.querySelector<HTMLElement>(".media-loader");
    if (!loader) return mediaReady;
    const fill = loader.querySelector<HTMLElement>(".media-loader-fill");
    if (!fill) return mediaReady;
    let progress = 0;
    let done = false;
    const step = () => {
      if (done) return;
      // Ease toward 92%: fast at first, slow near the top.
      const gap = 92 - progress;
      progress += Math.max(0.6, gap * 0.06);
      if (progress > 92) progress = 92;
      fill.style.width = `${progress}%`;
      window.setTimeout(step, 140);
    };
    step();
    return mediaReady.finally(() => {
      done = true;
      fill.style.width = "100%";
      window.setTimeout(() => {
        loader.classList.add("is-hidden");
      }, 220);
    });
  }

  function waitForMedia(el: HTMLImageElement | HTMLVideoElement): Promise<void> {
    return new Promise((resolve) => {
      if (el.tagName === "VIDEO") {
        const v = el as HTMLVideoElement;
        if (v.readyState >= 2) return resolve();
        const done = () => {
          v.removeEventListener("loadeddata", done);
          v.removeEventListener("error", done);
          resolve();
        };
        v.addEventListener("loadeddata", done);
        v.addEventListener("error", done);
      } else {
        const img = el as HTMLImageElement;
        if (img.complete && img.naturalWidth > 0) return resolve();
        const done = () => {
          img.removeEventListener("load", done);
          img.removeEventListener("error", done);
          resolve();
        };
        img.addEventListener("load", done);
        img.addEventListener("error", done);
      }
    });
  }

  // ---------- Project video modal ----------
  const modal = document.getElementById("video-modal") as HTMLElement | null;
  const modalVideo = modal?.querySelector<HTMLVideoElement>(".video-modal-video") ?? null;
  const modalImage = modal?.querySelector<HTMLImageElement>(".video-modal-image") ?? null;
  const modalTitle = modal?.querySelector<HTMLElement>(".video-modal-title") ?? null;

  function openMediaModal(src: string, title: string, kind: "video" | "image") {
    if (!modal) return;
    modal.dataset.kind = kind;
    if (modalTitle) modalTitle.textContent = title;
    if (kind === "video" && modalVideo) {
      // Pause any inline preview <video> before the modal starts loading — two
      // media elements pointing at the same URL fight over the download, and
      // the modal ends up stuck around 0.7s ("Loading" spinner never clears).
      document.querySelectorAll<HTMLVideoElement>(
        ".proj-video video, .paper-preview video",
      ).forEach((v) => v.pause());
      modalVideo.src = src;
      modalVideo.currentTime = 0;
      modalVideo.muted = true;
      modalVideo.play().catch(() => {});
    } else if (kind === "image" && modalImage) {
      modalImage.src = src;
      modalImage.alt = title;
    }
    modal.classList.add("is-open");
    modal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }

  function closeVideoModal() {
    if (!modal) return;
    modal.classList.remove("is-open");
    modal.setAttribute("aria-hidden", "true");
    if (modalVideo) {
      modalVideo.pause();
      modalVideo.removeAttribute("src");
      modalVideo.load();
    }
    if (modalImage) {
      modalImage.removeAttribute("src");
    }
    document.body.style.overflow = "";
  }

  modal?.querySelector(".video-modal-backdrop")?.addEventListener("click", closeVideoModal);
  modal?.querySelector(".video-modal-close")?.addEventListener("click", closeVideoModal);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal?.classList.contains("is-open")) closeVideoModal();
  });

  function bindProjectVideos() {
    document.querySelectorAll<HTMLElement>(".proj-video").forEach((btn) => {
      if (btn.dataset.videoBound === "1") return;
      btn.dataset.videoBound = "1";
      btn.addEventListener("click", (e) => {
        if (btn.classList.contains("is-ready")) {
          e.preventDefault();
          const src = btn.dataset.video || "";
          const title = btn.dataset.title || "";
          if (src) openMediaModal(src, title, "video");
        }
      });
    });
  }

  function bindPaperPreviewButtons() {
    document.querySelectorAll<HTMLElement>(".paper-preview-btn").forEach((btn) => {
      if (btn.dataset.mediaBound === "1") return;
      btn.dataset.mediaBound = "1";
      btn.addEventListener("click", (e) => {
        if (!btn.classList.contains("is-ready")) return;
        e.preventDefault();
        const src = btn.dataset.media || "";
        const title = btn.dataset.title || "";
        const kind = (btn.dataset.mediaType === "video" ? "video" : "image") as
          | "video"
          | "image";
        if (src) openMediaModal(src, title, kind);
      });
    });
  }

  function bindPublications() {
    document.querySelectorAll<HTMLElement>(".paper-item").forEach((parent) => {
      const v = parent.querySelector<HTMLVideoElement>(".paper-preview video");
      if (!v || parent.dataset.videoBound === "1") return;
      parent.dataset.videoBound = "1";
      parent.addEventListener("mouseenter", () => {
        if (v.readyState >= 2) v.play().catch(() => {});
      });
      parent.addEventListener("mouseleave", () => {
        v.pause();
        v.currentTime = 0;
      });
    });
    document.querySelectorAll<HTMLButtonElement>(".paper-bibtex").forEach((btn) => {
      if (btn.dataset.copyBound === "1") return;
      btn.dataset.copyBound = "1";
      btn.addEventListener("click", async () => {
        const text = btn.dataset.bibtex || "";
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          const ta = document.createElement("textarea");
          ta.value = text;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand("copy");
          ta.remove();
        }
        const original = btn.textContent;
        btn.textContent = "Copied";
        btn.classList.add("copied");
        setTimeout(() => {
          btn.textContent = original;
          btn.classList.remove("copied");
        }, 1600);
      });
    });
  }

  // Staged asset loading: GLB → project videos → paper previews.
  // The reader's eye lands on the hero first; nothing below it competes for
  // bandwidth until the 3D avatar is on screen.
  function activateProjectVideos() {
    document.querySelectorAll<HTMLElement>(".proj-video").forEach((container) => {
      const v = container.querySelector<HTMLVideoElement>("video[data-src]");
      if (!v) return;
      const src = v.dataset.src;
      if (!src) return;
      v.preload = "metadata";
      v.src = src;
      v.removeAttribute("data-src");
      driveLoader(container, waitForMedia(v)).then(() => {
        container.classList.add("is-ready");
      });
    });
  }

  function activatePaperPreviews() {
    // Both images and videos wait for the 3D avatar to finish. Once activated,
    // they swap their real src in via IntersectionObserver so the initial
    // burst of GET requests stays small (Firefox: 6/host).
    const swapImg = (img: HTMLImageElement) => {
      const src = img.dataset.src;
      if (!src) return;
      img.src = src;
      img.removeAttribute("data-src");
      const container = img.closest<HTMLElement>(".paper-preview");
      if (container) {
        driveLoader(container, waitForMedia(img)).then(() => {
          container.classList.add("is-ready");
        });
      }
    };
    const swapVideo = (v: HTMLVideoElement) => {
      const src = v.dataset.src;
      if (!src) return;
      v.preload = "metadata";
      v.src = src;
      v.removeAttribute("data-src");
      const container = v.closest<HTMLElement>(".paper-preview");
      if (container) {
        driveLoader(container, waitForMedia(v)).then(() => {
          container.classList.add("is-ready");
        });
      }
    };
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver((entries, obs) => {
        for (const entry of entries) {
          const el = entry.target as HTMLElement;
          if (entry.isIntersecting) {
            if (el.tagName === "IMG") swapImg(el as HTMLImageElement);
            else swapVideo(el as HTMLVideoElement);
            obs.unobserve(el);
          }
        }
      }, { rootMargin: "200px" });
      document.querySelectorAll<HTMLElement>(
        ".paper-preview img[data-src], .paper-preview video[data-src]",
      ).forEach((el) => io.observe(el));
    } else {
      document.querySelectorAll<HTMLImageElement>(
        ".paper-preview img[data-src]",
      ).forEach(swapImg);
      document.querySelectorAll<HTMLVideoElement>(
        ".paper-preview video[data-src]",
      ).forEach(swapVideo);
    }
  }

  function startStagedLoading() {
    // If the 3D avatar takes too long (or errors silently), don't hold the rest
    // of the page hostage — fall back after 4s.
    let started = false;
    const kick = () => {
      if (started) return;
      started = true;
      activateProjectVideos();
      // Small gap so the video metadata requests don't collide with paper
      // previews arriving via IntersectionObserver.
      setTimeout(activatePaperPreviews, 150);
    };
    window.addEventListener("viewer3d:ready", kick, { once: true });
    setTimeout(kick, 4000);
  }

  bindPublications();
  bindProjectVideos();
  bindPaperPreviewButtons();
  startStagedLoading();
  document.addEventListener("astro:page-load", () => {
    bindPublications();
    bindProjectVideos();
    bindPaperPreviewButtons();
    startStagedLoading();
  });
</script>
